# Normalize line endings on checkin / checkout
* text=auto eol=lf

# Force CRLF for Windows-only files
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Force LF for Unix shell scripts
*.sh        text eol=lf

# Markdown / docs as text
*.md        text
*.txt       text
*.yml       text
*.yaml      text
*.json      text
*.xml       text

# Source code as text
*.cs        text diff=csharp
*.csproj    text
*.sln       text
*.py        text diff=python

# Treat .docx and other Office documents as binary
*.docx      binary
*.dotx      binary
*.xlsx      binary
*.pptx      binary
*.pdf       binary

# Treat compiled / binary engine artifacts as binary
*.dll       binary
*.exe       binary
*.so        binary
*.dylib     binary
*.zip       binary
